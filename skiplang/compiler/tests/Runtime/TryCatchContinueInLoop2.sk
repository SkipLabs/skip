module Runtime_TryCatchContinueInLoop2;
class MyException() extends Exception {
  fun getMessage(): String {
    ""
  }
}

@exptest
fun main(): void {
  print_raw(
    try {
      throw MyException()
    } catch {
    | MyException _ ->
      i = 0;
      while (i == 0) {
        !i = i + 1;
        continue
      };
      "Pass\n"
    | _ -> "Fail"
    }
  )
}
module end;
