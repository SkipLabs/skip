module Visibility_Private4;
base class X final {private foo: String} {
  deferred static fun empty(foo: String): this {
    static{foo => foo}
  }
  fun bar(): String {
    this.foo
  }
}

base class Y extends X
class Z extends Y

@exptest
fun main(): void {
  print_raw(Z::empty("Pass\n").bar())
}
module end;
