module Typechecking_OverridableGeneric6;
base class MyParent<-P: Orderable> {
  fun foo<P2: Orderable>[P: P2](): SortedMap<P2, void>;
}

class C<T: Orderable>() extends MyParent<T> {
  fun foo(): SortedMap<T, void> {
    SortedMap[]
  }
}

@exptest
fun main(): void {
  print_string("Pass")
}
module end;
