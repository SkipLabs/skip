module TypecheckingMatchScopedConstantsM;

const C: Int = 1;

class MC() {
  const C: Int = 2;
}

/*
TODO: Enable matching on non-overridable class constants.
fun main(): void {
  (1, 1, 2, 2, 3, 4) match {
  | (C, TypecheckingMatchScopedConstantsM.C, MC::C, TypecheckingMatchScopedConstantsM.MC::C, C::C, GC) -> print_string("Pass");
  | _ -> void;
  };
}
*/

fun main(): void {
  (1, 1, 1, 4, 4) match {
  | (
    C,
    TypecheckingMatchScopedConstantsM.C,
    .TypecheckingMatchScopedConstantsM.C,
    TypecheckingMatchScopedConstants.GC,
    .TypecheckingMatchScopedConstants.GC,
  ) ->
    print_string("Pass")
  | _ -> void
  };
}

module end;

module TypecheckingMatchScopedConstants;

class C() {
  const C: Int = 3;
}

const GC: Int = 4;

/*
TODO: Enable matching on non-overridable class constants.
fun main(): void {
  TypecheckingMatchScopedConstantsM.main();
  (1, 2, 3, 4) match {
  | (TypecheckingMatchScopedConstantsM.C, TypecheckingMatchScopedConstantsM.MC::C, C::C, GC) -> print_string("Pass");
  | _ -> void;
  };
}
*/

fun main(): void {
  TypecheckingMatchScopedConstantsM.main();
  (1, 1, 4, 4) match {
  | (
    TypecheckingMatchScopedConstantsM.C,
    .TypecheckingMatchScopedConstantsM.C,
    GC,
    .TypecheckingMatchScopedConstants.GC,
  ) ->
    print_string("Pass")
  | _ -> void
  };
}

module end;
