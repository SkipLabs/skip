module SyntaxFactory;
fun main(): void {
  foo = SyntaxFactoryFoo.Factory()[42];
  print_raw(if (foo.getAttr() == 42) "OK\n" else "FAILED")
}

module end;

module SyntaxFactoryFoo;

class .SF_Foo{private attr: Int} {
  fun getAttr(): Int {
    this.attr
  }
}

class Factory() {
  fun get(attr: Int): SF_Foo {
    SF_Foo{attr => attr}
  }
}

module end;
