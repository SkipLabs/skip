module Syntax_MatchIfGrouping;
base class MyBase final () {
  children =
  | Foo
  | Bar
}

@exptest
fun main(): void {
  x: MyBase = Foo();
  print_raw(
    x match {
    | Foo() ->
      if (true) {
        "Pass\n"
      } else {
        "false"
      }
    | _ -> "wrong"
    },
  )
}
module end;
