module Syntax_WhenPattern8;
base class Bar {
  children =
  | Foo(Int)
  | Baz(Bool)
}

@exptest
fun main(): void {
  print_raw(
    Foo(1) match {
    | i @ Foo(_) if (
      i match {
      | Foo(2) -> false
      | Foo(
        x,
      ) if ({
        y = x;
        x == y
      }) ->
        true
      | _ -> false
      }
    ) ->
      "Pass\n"
    | _ -> "Fail\n"
    },
  )
}
module end;
