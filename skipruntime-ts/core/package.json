{
  "name": "@skipruntime/core",
  "version": "0.0.23",
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js",
    "./internal.js": "./dist/src/internal.js",
    "./binding.js": "./dist/src/binding.js",
    "./json.js": "./dist/skiplang-json/index.js",
    "./json-internal.js": "./dist/skiplang-json/internal.js",
    "./std.js": "./dist/skiplang-std/index.js",
    "./std-internal.js": "./dist/skiplang-std/internal.js"
  },
  "scripts": {
    "build-alt": "node ../../prebuild.mjs skiplang-std skiplang-json && tsc --outDir ../skipper/core",
    "clean-alt": "rm -rf ../skipper/core/src ../skipper/core/skiplang-std ../skipper/core/skiplang-json ../skipper/core/tsconfig.tsbuildinfo",
    "build": "node ../../prebuild.mjs skiplang-std skiplang-json && tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo skiplang-std skiplang-json && npm run clean-alt",
    "lint": "eslint"
  }
}
